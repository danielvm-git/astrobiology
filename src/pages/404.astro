---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
	<main class="flex-1 flex flex-col items-center justify-center text-center px-4">
		<h1 class="text-9xl font-black text-slate-100 mb-8">404</h1>
		<p class="text-2xl font-serif italic text-slate-500 mb-12">Oops! You've wandered into a cosmic void.</p>
		<a href="/" class="bg-primary text-white px-8 py-4 rounded-full font-black uppercase tracking-widest hover:shadow-xl transition-all">
			Return to Earth
		</a>
	</main>
</Layout>
