---
import { Clock } from 'lucide-vue-next';
import { getImageUrl, CATEGORIES } from '../lib/appwrite';
import { formatDate, cn } from '../lib/utils';

interface Props {
	article: any;
	variant?: 'default' | 'featured' | 'compact';
	class?: string;
}

const { article, variant = 'default', class: className } = Astro.props;
const currentLocale = Astro.currentLocale || 'en';

const title = article.translation?.title || article.title;
const slug = article.translation?.slug || article.slug;
const excerpt = article.translation?.excerpt || article.excerpt;

const category = CATEGORIES.find((c) => c.slug === article.category);
const imageUrl = article.featuredImage ? getImageUrl(article.featuredImage, 800, 500) : null;

const getLocalePath = (path: string) => {
	if (currentLocale === 'en') return path;
	return `/${currentLocale}${path}`;
};
---

{article && (
	<div class={cn("card bg-background shadow-xl hover:shadow-2xl transition-all duration-300 border border-neutral-500/20 group", className)}>
		<figure class="relative h-48 overflow-hidden">
			<a href={getLocalePath(`/articles/${slug}`)} class="w-full h-full">
				{imageUrl ? (
					<img 
						src={imageUrl} 
						alt={article.featuredImageAlt || title} 
						class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						loading="lazy"
					/>
				) : (
					<div class="flex h-full w-full items-center justify-center bg-neutral-50 text-4xl">🔭</div>
				)}
			</a>
			{category && (
				<div class="absolute top-4 left-4">
					<a 
						href={getLocalePath(`/categories/${category.slug}`)}
						class="badge badge-primary font-bold uppercase text-[10px] tracking-wider"
					>
						{category.name}
					</a>
				</div>
			)}
		</figure>
		
		<div class="card-body p-6">
			<div class="flex items-center gap-2 text-xs opacity-70 mb-2 uppercase font-bold tracking-widest">
				<time>{formatDate(article.publishedAt || article.$createdAt, currentLocale)}</time>
			</div>
			
			<h2 class="card-title text-xl font-bold leading-tight group-hover:text-primary transition-colors duration-300">
				<a href={getLocalePath(`/articles/${slug}`)}>{title}</a>
			</h2>
			
			<p class="text-sm opacity-80 line-clamp-3 my-4 italic">
				{excerpt}
			</p>

			<div class="card-actions justify-between items-center mt-4 pt-4 border-t border-neutral-500/20">
				<div class="flex items-center gap-1.5 text-[10px] font-bold opacity-50 uppercase tracking-widest">
					<Clock class="h-3 w-3" />
					5 min
				</div>
				<a href={getLocalePath(`/articles/${slug}`)} class="btn btn-primary btn-sm btn-outline">Read More</a>
			</div>
		</div>
	</div>
)}
