---
import { Clock } from 'lucide-vue-next';
import { getImageUrl, CATEGORIES } from '../lib/appwrite';
import { formatDate, cn } from '../lib/utils';

interface Props {
	article: any;
	variant?: 'default' | 'featured' | 'compact';
	class?: string;
}

const { article, variant = 'default', class: className } = Astro.props;
const currentLocale = Astro.currentLocale || 'en';

const title = article.translation?.title || article.title;
const slug = article.translation?.slug || article.slug;
const excerpt = article.translation?.excerpt || article.excerpt;

const category = CATEGORIES.find((c) => c.slug === article.category);
const imageUrl = article.featuredImage ? getImageUrl(article.featuredImage, 800, 500) : null;

const getLocalePath = (path: string) => {
	if (currentLocale === 'en') return path;
	return `/${currentLocale}${path}`;
};
---

{article && (
	<article class={cn(
		"group overflow-hidden bg-white border border-slate-100 transition-all duration-500 hover:shadow-xl hover:border-primary/20 flex flex-col h-full",
		variant === 'featured' && "md:flex-row md:aspect-[21/9]",
		className
	)}>
		<a href={getLocalePath(`/articles/${slug}`)} class={cn(
			"block overflow-hidden shrink-0",
			variant === 'featured' ? "md:w-1/2 h-full" : "aspect-[16/10]"
		)}>
			<div class="relative h-full w-full bg-slate-50">
				{imageUrl ? (
					<img 
						src={imageUrl} 
						alt={article.featuredImageAlt || title} 
						class="h-full w-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
						loading="lazy"
					/>
				) : (
					<div class="flex h-full w-full items-center justify-center grayscale opacity-30 text-4xl">🔭</div>
				)}
				{article.featured && (
					<div class="absolute top-4 left-4">
						<span class="bg-primary text-white text-[9px] font-black uppercase tracking-widest px-2 py-1 shadow-lg">
							Featured
						</span>
					</div>
				)}
			</div>
		</a>
		
		<div class="p-6 flex flex-col flex-1">
			{category && (
				<div class="mb-4">
					<a 
						href={getLocalePath(`/categories/${category.slug}`)}
						class="text-primary text-[10px] font-black uppercase tracking-[0.2em] hover:underline"
					>
						{category.name}
					</a>
				</div>
			)}
			
			<a href={getLocalePath(`/articles/${slug}`)} class="group-hover:text-primary transition-colors duration-300">
				<h3 class={cn(
					"font-bold leading-[1.15] text-slate-900 mb-4 font-serif group-hover:underline decoration-primary/30 decoration-2 underline-offset-4 transition-all text-balance",
					variant === 'featured' ? "text-2xl md:text-4xl" : "text-xl md:text-2xl"
				)}>
					{title}
				</h3>
			</a>
			
			<p class="text-slate-600 text-base leading-relaxed font-serif line-clamp-3 mb-8 italic">
				{excerpt}
			</p>

			<div class="mt-auto pt-6 border-t border-slate-50 flex items-center justify-between">
				<div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
					{formatDate(article.publishedAt || article.$createdAt, currentLocale)}
				</div>
				<div class="flex items-center gap-1.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
					<Clock className="h-3 w-3" />
					5 min
				</div>
			</div>
		</div>
	</article>
)}
