---
import { Telescope, Menu } from 'lucide-vue-next';
import LanguageSwitcher from './LanguageSwitcher.vue';

const currentLocale = Astro.currentLocale || 'en';
const locales = ['en', 'pt-br', 'es', 'ja', 'nl', 'zh'];

const navItems = [
	{ name: 'Home', path: '/' },
	{ name: 'Articles', path: '/articles' },
	{ name: 'About', path: '/about' },
];

const getLocalePath = (path: string) => {
	if (currentLocale === 'en') return path;
	return `/${currentLocale}${path === '/' ? '' : path}`;
};
---

<header class="sticky top-0 z-50 bg-background/95 backdrop-blur border-b border-neutral-500/20">
	<div class="navbar mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="navbar-start">
			<div class="dropdown">
				<div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
					<Menu class="h-5 w-5" />
				</div>
				<ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-background rounded-box w-52 border border-neutral-500/20 uppercase font-bold text-[10px] tracking-widest">
					{navItems.map((item) => (
						<li><a href={getLocalePath(item.path)}>{item.name}</a></li>
					))}
					<li><a href="/admin">Admin</a></li>
				</ul>
			</div>
			<a href={getLocalePath('/')} class="btn btn-ghost flex items-center gap-2 px-2">
				<Telescope class="h-6 w-6 text-primary" />
				<span class="text-sm font-black uppercase tracking-widest hidden sm:inline-block">Astrobiology</span>
			</a>
		</div>
		
		<div class="navbar-center hidden lg:flex">
			<ul class="menu menu-horizontal px-1 uppercase font-bold text-[10px] tracking-widest opacity-70">
				{navItems.map((item) => (
					<li><a href={getLocalePath(item.path)} class="hover:text-primary transition-colors">{item.name}</a></li>
				))}
				<li><a href="/admin" class="hover:text-primary transition-colors">Admin</a></li>
			</ul>
		</div>

		<div class="navbar-end gap-2">
			<LanguageSwitcher client:load currentLocale={currentLocale} locales={locales} variant="header" />
			<div class="hidden sm:flex">
				<a href="/admin" class="btn btn-primary btn-sm btn-outline px-6">Admin Login</a>
			</div>
		</div>
	</div>
</header>
