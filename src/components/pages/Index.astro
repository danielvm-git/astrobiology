---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../ArticleCard.astro';
import { getArticles } from '../../lib/appwrite';

const currentLocale = Astro.currentLocale || 'en';
const articles = await getArticles(currentLocale, 6);
---

<Layout title="Astrobiology - Exploring life in the universe">
	<main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 flex-1">
		<div class="mb-12 border-b border-slate-100 pb-12">
			<h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-6 tracking-tighter">Astrobiology</h1>
			<p class="text-xl md:text-2xl text-slate-500 font-serif max-w-3xl leading-relaxed italic">
				Exploring the origins, evolution, and future of life in the universe. Professional science journalism with a cosmic perspective.
			</p>
		</div>
		
		<section>
			<div class="flex items-center justify-between mb-8">
				<h2 class="text-xs font-black uppercase tracking-[0.3em] text-slate-400">Latest Articles</h2>
				<a href="/articles" class="text-xs font-black uppercase tracking-widest text-primary hover:underline">View All</a>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{articles.map((article) => (
					<ArticleCard article={article} />
				))}
			</div>

			{articles.length === 0 && (
				<div class="py-20 text-center border-2 border-dashed border-slate-100 rounded-3xl">
					<p class="text-slate-400 font-serif italic text-lg">No articles found. Stay tuned for cosmic updates.</p>
				</div>
			)}
		</section>
	</main>
</Layout>
